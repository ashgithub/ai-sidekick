#!/usr/bin/env bash
set -euo pipefail

# Validate app integrity quickly.
#
# Usage:
#   ./bin/sidekick-check
#
# What it runs:
#   1) Ruff lint
#   2) Compile check
#   3) Pytest suite

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${ROOT_DIR}"
export UV_CACHE_DIR="${UV_CACHE_DIR:-${TMPDIR:-/tmp}/ai-sidekick-uv-cache}"
export UV_PROJECT_ENVIRONMENT="${UV_PROJECT_ENVIRONMENT:-${TMPDIR:-/tmp}/ai-sidekick-venv}"

echo "[1/3] Lint (ruff)"
uv run ruff check src tests scripts bin

echo "[2/3] Compile check"
uv run python -m compileall -q src tests scripts bin

echo "[3/3] Tests"
uv run pytest -q

echo "All checks passed."
